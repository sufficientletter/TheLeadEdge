# TheLeadEdge Environment Configuration
# Copy to .env and fill in your values

# Application
APP_ENV=development
LOG_LEVEL=DEBUG

# State/Market
STATE=FL
MARKET_NAME=Southwest Florida

# Database
DATABASE_URL=sqlite+aiosqlite:///./theleadedge.db

# Email (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
BRIEFING_RECIPIENT=trevormoen@gmail.com

# Follow Up Boss CRM (Phase 2)
# FUB_API_KEY=your-fub-api-key
# FUB_BASE_URL=https://api.followupboss.com/v1

# REDX (Phase 2)
# REDX_API_KEY=your-redx-api-key

# ATTOM (Phase 5)
# ATTOM_API_KEY=your-attom-api-key

# BatchLeads (Phase 4)
# BATCHLEADS_API_KEY=your-batchleads-api-key

# Paths
MLS_IMPORT_DIR=data/mls_imports
PROCESSED_DIR=data/processed
CONFIG_DIR=config
